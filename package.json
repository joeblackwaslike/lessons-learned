{
  "name": "lessons-learned",
  "version": "0.1.0",
  "description": "Automatic mistake capture and proactive lesson injection for AI coding agents",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=22.5"
  },
  "scripts": {
    "lessons": "node --no-warnings scripts/lessons.mjs",
    "scan": "node --no-warnings scripts/lessons.mjs scan",
    "build": "node --no-warnings scripts/lessons.mjs build",
    "test": "node --test 'tests/**/*.test.mjs'",
    "test:unit": "node --test 'tests/unit/**/*.test.mjs'",
    "test:integration": "node --test 'tests/integration/**/*.test.mjs'",
    "test:e2e": "node --test 'tests/e2e/**/*.test.mjs'",
    "test:coverage": "node --test --experimental-test-coverage 'tests/**/*.test.mjs'",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit -p jsconfig.json",
    "docs": "mkdocs serve",
    "docs:build": "mkdocs build -s",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{mjs,js}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^25.5.0",
    "eslint": "^9.39.4",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.92.0",
    "sqlite-vec": "^0.1.9"
  }
}

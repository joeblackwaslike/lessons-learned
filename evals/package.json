{
  "name": "@lessons-learned/evals",
  "version": "0.1.0",
  "description": "Eval framework for lessons-learned lesson effectiveness",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=22.5"
  },
  "scripts": {
    "eval": "promptfoo eval --config promptfooconfig.yaml --output results/cache/latest-run.json",
    "eval:smoke": "promptfoo eval --config promptfooconfig.yaml --filter-pattern 'TC-H3|TC-G1' --output results/cache/smoke-run.json",
    "eval:gen": "node scripts/generate-scenarios.mjs",
    "eval:report": "node scripts/render-report.mjs --input results/cache/smoke-run.json",
    "eval:report:latest": "node scripts/render-report.mjs --input results/cache/latest-run.json",
    "eval:runs": "node scripts/list-runs.mjs",
    "eval:clean": "rm -rf results/cache/*.json results/cache/control-*.json"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.54.0",
    "promptfoo": "^0.121.0",
    "ulid": "^2.3.0",
    "js-yaml": "^4.1.0"
  }
}
